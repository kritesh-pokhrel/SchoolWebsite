@{
    ViewData["Title"] = "Home";
}

<main class="school-home">

    <!-- HERO SECTION -->
    <section class="hero-banner">
        <div class="hero-overlay">
            <div class="container">
                <div class="hero-content">
                    <span class="hero-tag">WELCOME TO GEMS SCHOOL</span>
                    <h1>Teachers' Professional Development</h1>
                    <p>
                        Providing quality education with modern learning methods,
                        innovation, and holistic student development.
                    </p>

                    <div class="hero-buttons">
                        <a href="#" class="btn-primary">Apply Now</a>
                        <a href="#" class="btn-secondary">Learn More</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ABOUT -->
    <section class="home-about">
        <div class="container">
            <div class="about-grid">

                <div class="about-card">
                    <div class="about-card-header">
                        <h3>Register for More Info</h3>
                    </div>

                    <form class="info-form">
                        <div class="form-group">
                            <input type="text" placeholder="Full Name">
                        </div>

                        <div class="form-group">
                            <input type="email" placeholder="Email Address">
                        </div>

                        <div class="form-group">
                            <input type="text" placeholder="Phone Number">
                        </div>

                        <div class="form-group">
                            <select>
                                <option>Select Grade</option>
                                <option>Grade 1</option>
                                <option>Grade 2</option>
                                <option>Grade 3</option>
                            </select>
                        </div>

                        <button type="submit" class="btn-primary w-100">
                            Submit
                        </button>
                    </form>
                </div>

                <div class="about-content">
                    <span class="section-mini-title">WELCOME MESSAGE</span>

                    <h2>Welcome To GEMS SCHOOL</h2>

                    <p>
                        GEMS SCHOOL is dedicated to delivering quality education
                        through innovation, discipline, and student-centered learning.
                    </p>

                    <p>
                        We focus on academic excellence, leadership development,
                        extracurricular activities, and character building to help
                        students achieve their full potential.
                    </p>

                    <div class="about-buttons">
                        <a href="#" class="btn-primary">About Us</a>
                        <a href="#" class="btn-secondary dark-btn">Contact</a>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- WHY CHOOSE -->
    <section class="why-section">
        <div class="container">

            <div class="section-header">
                <span class="section-mini-title">WHY CHOOSE US</span>
                <h2>Why Choose GEMS</h2>
            </div>

            <div class="why-grid">

                <div class="why-card">
                    <div class="why-icon">
                        <i class="fas fa-user-graduate"></i>
                    </div>

                    <h3>Academic Excellence</h3>

                    <p>
                        High-quality curriculum and dedicated faculty members.
                    </p>
                </div>

                <div class="why-card">
                    <div class="why-icon">
                        <i class="fas fa-book-open"></i>
                    </div>

                    <h3>Modern Learning</h3>

                    <p>
                        Interactive classrooms and practical learning methods.
                    </p>
                </div>

                <div class="why-card">
                    <div class="why-icon">
                        <i class="fas fa-futbol"></i>
                    </div>

                    <h3>Extra Activities</h3>

                    <p>
                        Sports, arts, clubs, and leadership opportunities.
                    </p>
                </div>

                <div class="why-card">
                    <div class="why-icon">
                        <i class="fas fa-globe"></i>
                    </div>

                    <h3>Global Exposure</h3>

                    <p>
                        International standard learning and student development.
                    </p>
                </div>

            </div>
        </div>
    </section>

    <!-- THUNDERBOLTS -->
    <section class="thunder-section">
        <div class="container">

            <div class="thunder-grid">

                <div class="thunder-logo">
                    <img src="https://via.placeholder.com/250x250/003366/ffffff?text=LOGO"
                         alt="School Logo">
                </div>

                <div class="thunder-content">

                    <span class="section-mini-title">
                        THUNDERBOLTS
                    </span>

                    <h2>Welcome To The Home Of Thunderbolts</h2>

                    <p>
                        We believe every child deserves a safe, supportive,
                        and inspiring learning environment.
                    </p>

                    <p>
                        Our programs are designed to build confidence,
                        creativity, discipline, and leadership qualities.
                    </p>

                </div>

            </div>

        </div>
    </section>

    <!-- NEWS -->
    <section class="news-section">
        <div class="container">

            <div class="section-header">
                <span class="section-mini-title">NEWS & UPDATES</span>
                <h2>What's Happening</h2>
            </div>

            <div class="news-grid">

                <!-- LATEST HAPPENINGS -->
                <div class="news-box">

                    <h3 class="box-title">Latest Happenings</h3>

                    <div class="news-item">
                        <img src="https://via.placeholder.com/100x80" />
                        <div>
                            <h4>School Event Program</h4>
                            <p>June 12, 2026</p>
                        </div>
                    </div>

                    <div class="news-item">
                        <img src="https://via.placeholder.com/100x80" />
                        <div>
                            <h4>Science Exhibition</h4>
                            <p>June 18, 2026</p>
                        </div>
                    </div>

                    <div class="news-item">
                        <img src="https://via.placeholder.com/100x80" />
                        <div>
                            <h4>Annual Day Preparation</h4>
                            <p>June 20, 2026</p>
                        </div>
                    </div>

                </div>

                <!-- UPCOMING EVENTS -->
                <div class="news-box">

                    <h3 class="box-title">Upcoming Events</h3>

                    <div class="event-card">
                        <div class="event-date">
                            <span>12</span>
                            <small>JUN</small>
                        </div>

                        <div>
                            <h4>Sports Week</h4>
                            <p>9:00 AM</p>
                        </div>
                    </div>

                    <div class="event-card">
                        <div class="event-date">
                            <span>25</span>
                            <small>JUN</small>
                        </div>

                        <div>
                            <h4>Parent Meeting</h4>
                            <p>11:00 AM</p>
                        </div>
                    </div>

                    <div class="event-card">
                        <div class="event-date">
                            <span>30</span>
                            <small>JUN</small>
                        </div>

                        <div>
                            <h4>Quiz Competition</h4>
                            <p>10:00 AM</p>
                        </div>
                    </div>

                </div>

                <!-- NOTICES -->
                <div class="news-box">

                    <h3 class="box-title">Important Notices</h3>

                    <div class="notice-item">
                        <span class="notice-badge">NEW</span>
                        <h4>Admission Open 2026-27</h4>
                    </div>

                    <div class="notice-item">
                        <span class="notice-badge urgent">URGENT</span>
                        <h4>Holiday Announcement</h4>
                    </div>

                    <div class="notice-item">
                        <span class="notice-badge info">INFO</span>
                        <h4>Exam Schedule Released</h4>
                    </div>

                </div>

            </div>
        </div>
    </section>

    <!-- APP SECTION -->
    <section class="app-section">
        <div class="container">

            <div class="app-grid">

                <div class="app-image">
                    <img src="https://via.placeholder.com/300x500/003366/ffffff?text=Mobile+App">
                </div>

                <div class="app-content">
                    <span class="section-mini-title">
                        VIDYA APP
                    </span>

                    <h2>Download Vidya App</h2>

                    <p>
                        Access school updates, notices, attendance,
                        assignments, and announcements directly from your phone.
                    </p>

                    <div class="store-buttons">
                        <a href="#" class="store-btn">
                            <i class="fab fa-google-play"></i>
                            Google Play
                        </a>

                        <a href="#" class="store-btn">
                            <i class="fab fa-apple"></i>
                            App Store
                        </a>
                    </div>

                </div>

            </div>

        </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section">
        <div class="container">

            <div class="section-header light">
                <span class="section-mini-title">
                    HAVE QUESTIONS
                </span>

                <h2>FAQs</h2>
            </div>

            <div class="faq-wrapper">

                <div class="faq-item active">
                    <div class="faq-question">
                        <h4>How can I apply for admission?</h4>
                        <i class="fas fa-plus"></i>
                    </div>

                    <div class="faq-answer">
                        <p>
                            You can apply online or visit our school office.
                        </p>
                    </div>
                </div>

                <div class="faq-item">
                    <div class="faq-question">
                        <h4>Do you provide transportation?</h4>
                        <i class="fas fa-plus"></i>
                    </div>

                    <div class="faq-answer">
                        <p>
                            Yes, transportation is available in major areas.
                        </p>
                    </div>
                </div>
                <div class="hero-buttons">
                    <a href="#" class="btn-primary">Apply Now</a>
                    <a href="#" class="btn-primary">Learn More</a>
                </div>
            </div>

        </div>
    </section>

    <!-- ACHIEVERS -->
    <section class="achievers-section">
        <div class="container">

            <div class="section-header">
                <span class="section-mini-title">
                    OUR STUDENTS
                </span>

                <h2>High Achievers</h2>
            </div>

            <div class="achiever-grid">

                <div class="achiever-card">
                    <img src="https://via.placeholder.com/250x250/d90429/ffffff?text=Student">
                    <h4>Student Name</h4>
                    <p>GPA: 4.0</p>
                </div>

                <div class="achiever-card">
                    <img src="https://via.placeholder.com/250x250/f77f00/ffffff?text=Student">
                    <h4>Student Name</h4>
                    <p>GPA: 4.0</p>
                </div>

                <div class="achiever-card">
                    <img src="https://via.placeholder.com/250x250/003366/ffffff?text=Student">
                    <h4>Student Name</h4>
                    <p>GPA: 4.0</p>
                </div>

                <div class="achiever-card">
                    <img src="https://via.placeholder.com/250x250/6a4c93/ffffff?text=Student">
                    <h4>Student Name</h4>
                    <p>GPA: 4.0</p>
                </div>

            </div>
        </div>
    </section>

    <!-- CONTACT -->
  <section class="contact-section">
    <div class="container">

        <div class="section-header">
            <span class="section-mini-title">CONTACT US</span>
            <h2>Get In Touch</h2>
        </div>

        <div class="contact-grid">

            <!-- LEFT: FORM -->
            <div class="contact-form-wrapper">

                <h3>Send Us A Message</h3>

                <form class="contact-form">

                    <div class="form-row">
                        <div class="form-group">
                            <input type="text" placeholder="Full Name" />
                        </div>

                        <div class="form-group">
                            <input type="email" placeholder="Email Address" />
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <input type="text" placeholder="Phone Number" />
                        </div>

                        <div class="form-group">
                            <input type="text" placeholder="Subject" />
                        </div>
                    </div>

                    <div class="form-group">
                        <textarea rows="5" placeholder="Your Message"></textarea>
                    </div>

                    <button type="submit" class="btn-primary">
                        Send Message
                    </button>

                </form>
            </div>

            <!-- RIGHT: INFO -->
            <div class="contact-info-wrapper">

                <h3>Contact Information</h3>

                <div class="contact-info-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <div>
                        <h4>Address</h4>
                        <p>GEMS SCHOOL, Kathmandu, Nepal</p>
                    </div>
                </div>

                <div class="contact-info-item">
                    <i class="fas fa-phone"></i>
                    <div>
                        <h4>Phone</h4>
                        <p>+977-1-1234567</p>
                    </div>
                </div>

                <div class="contact-info-item">
                    <i class="fas fa-envelope"></i>
                    <div>
                        <h4>Email</h4>
                        <p>info@gemsschool.edu</p>
                    </div>
                </div>

                <div class="map-box">
                    <img src="https://via.placeholder.com/500x250/e0e0e0/333333?text=Google+Map+Location"
                         alt="Map" />
                </div>

            </div>

        </div>

    </div>
</section>

</main>w