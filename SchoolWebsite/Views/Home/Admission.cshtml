@{
    ViewData["Title"] = "Home";
}
<section class="admission-page">
    <div class="container">

        <div class="admission-layout">

            <!-- LEFT CONTENT -->
            <div class="admission-content">

                <div class="admission-heading">
                    <h2>
                        Admission <strong>Requirements</strong>
                    </h2>

                    <div class="heading-border"></div>
                </div>

                <p>
                    We welcome students from different backgrounds and provide
                    a supportive environment for learning and growth.
                </p>

                <p>
                    Parents are requested to complete the admission process
                    with the required documents and assessment procedures.
                </p>

                <!-- REQUIREMENT BOX -->
                <div class="requirement-wrapper">

                    <div class="requirement-tabs">
                        <button class="active">PRIMARY</button>
                        <button>MIDDLE</button>
                        <button>HIGH SCHOOL</button>
                    </div>

                    <div class="requirement-content">

                        <ul>
                            <li>Completed admission application form.</li>
                            <li>Copy of birth certificate.</li>
                            <li>Previous academic records and transcripts.</li>
                            <li>Passport size photographs.</li>
                            <li>Transfer certificate from previous school.</li>
                            <li>Entrance assessment interview.</li>
                        </ul>

                        <a href="#" class="admission-btn">
                            MAKE AN ENQUIRY
                        </a>

                    </div>

                </div>

                <!-- NOTE -->
                <div class="admission-note">
                    <p>
                        Admission is granted based on assessment,
                        seat availability and school policies.
                    </p>
                </div>

            </div>

            <!-- SIDEBAR -->
            <div class="admission-sidebar">

                <div class="sidebar-menu-box">

                    <h3>Admissions.</h3>

                    <ul>
                        <li><a href="#" class="active">Overview</a></li>
                        <li><a href="#">Admission Process</a></li>
                        <li><a href="#">Requirements</a></li>
                        <li><a href="#">Scholarships</a></li>
                        <li><a href="#">School Tour</a></li>
                        <li><a href="#">Contact</a></li>
                    </ul>

                </div>

            </div>

        </div>

    </div>
</section>