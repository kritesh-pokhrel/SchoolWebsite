@{
    ViewBag.Title = "Admission";
}

<section class="founder-page">

    <div class="container">

        <!-- PAGE HEADER -->
        <div class="page-header">
            <h1>
                Meet Our <span class="highlight">Founder</span>
            </h1>
            <p class="sub-text">
                The visionary behind our institution’s journey and success.
            </p>
        </div>

        <!-- FOUNDER SECTION -->
        <div class="founder-wrapper">

            <!-- IMAGE -->
            <div class="founder-image">
                <img src="https://via.placeholder.com/500x600"
                     alt="Founder Image">
            </div>

            <!-- CONTENT -->
            <div class="founder-content">

                <h2>Dr. John Doe</h2>

                <h4>Founder & Chairman</h4>

                <p>
                    Our founder established this institution with a vision to provide
                    quality education and holistic development for every child.
                    With decades of experience in education leadership, he has
                    dedicated his life to shaping future generations.
                </p>

                <p>
                    Under his guidance, the school has grown into a center of excellence,
                    focusing not only on academics but also on character building,
                    creativity, and innovation.
                </p>

                <div class="founder-quote">
                    "Education is not just about learning facts, but transforming lives."
                </div>

            </div>

        </div>

        <!-- MISSION / VISION -->
        <div class="founder-cards">

            <div class="info-card">
                <h3>Our Mission</h3>
                <p>
                    To provide high-quality education that nurtures knowledge, skills,
                    and values in students.
                </p>
            </div>

            <div class="info-card">
                <h3>Our Vision</h3>
                <p>
                    To become a leading institution that empowers students to succeed
                    globally with confidence and integrity.
                </p>
            </div>

            <div class="info-card">
                <h3>Our Values</h3>
                <p>
                    Discipline, excellence, respect, innovation, and lifelong learning.
                </p>
            </div>

        </div>

    </div>

</section>