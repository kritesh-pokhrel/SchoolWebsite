@{
    ViewData["Title"] = "Home";
}

<main class="home-page">
    <section class="hero-section">
        <div class="container">
            <div class="hero-content">
                <h1>Welcome to GEMS SCHOOL</h1>
                <div class="breadcrumb">
                    <a href="@Url.Action("Index", "Home")">Home</a>
                </div>
            </div>
        </div>
    </section>

    <section class="welcome-section">
        <div class="container">
            <div class="content-wrapper">
                <div class="main-content">
                    <h2>Welcome to Our School</h2>
                    <div class="welcome-text">
                        @if (!string.IsNullOrWhiteSpace(ViewBag.PageContent))
                        {
                            @Html.Raw(ViewBag.PageContent)
                        }
                        else
                        {
                            <p>GEMS SCHOOL is a premier educational institution dedicated to providing excellence in education. We believe in nurturing young minds and preparing them for a bright future.</p>
                            <p>Our commitment to academic excellence, combined with a focus on holistic development, ensures that every student reaches their full potential.</p>
                        }
                    </div>
                    <div class="welcome-images">
                        <img src="https://via.placeholder.com/600x300/003366/ffffff?text=School+Campus" alt="School Campus" />
                        <img src="https://via.placeholder.com/600x300/ff6600/ffffff?text=Students+Learning" alt="Students Learning" />
                    </div>
                </div>
                <aside class="sidebar">
                    <div class="related-links">
                        <h3>Quick Links</h3>
                        <ul>
                            <li><a href="@Url.Action("About", "Home")">About Us</a></li>
                            <li><a href="@Url.Action("Admission", "Home")">Admission</a></li>
                            <li><a href="@Url.Action("Academics", "Home")">Academics</a></li>
                            <li><a href="@Url.Action("Activities", "Home")">Activities</a></li>
                            <li><a href="@Url.Action("Contact", "Home")">Contact Us</a></li>
                        </ul>
                    </div>
                </aside>
            </div>
        </div>
    </section>

    <section class="who-we-are-section">
        <div class="container">
            <h2>Who We Are</h2>
            <div class="who-we-are-content">
                <p>At GEMS SCHOOL, we are more than just an educational institution. We are a community of learners, educators, and families working together to create a nurturing environment where students can thrive.</p>
                <p>Our experienced faculty members are dedicated to providing personalized attention to each student, ensuring that they receive the support they need to succeed academically and personally.</p>
            </div>
        </div>
    </section>

    <section class="employee-section">
        <div class="container">
            <h2>Our Team</h2>
            <div class="employee-grid">
                <div class="employee-card">
                    <img src="https://via.placeholder.com/150x150/003366/ffffff?text=Principal" alt="Principal" />
                    <h4>Dr. John Smith</h4>
                    <p>Principal</p>
                </div>
                <div class="employee-card">
                    <img src="https://via.placeholder.com/150x150/ff6600/ffffff?text=Vice+Principal" alt="Vice Principal" />
                    <h4>Mrs. Sarah Johnson</h4>
                    <p>Vice Principal</p>
                </div>
                <div class="employee-card">
                    <img src="https://via.placeholder.com/150x150/003366/ffffff?text=Academic+Director" alt="Academic Director" />
                    <h4>Mr. David Lee</h4>
                    <p>Academic Director</p>
                </div>
                <div class="employee-card">
                    <img src="https://via.placeholder.com/150x150/ff6600/ffffff?text=Admin+Head" alt="Admin Head" />
                    <h4>Ms. Emily Brown</h4>
                    <p>Administration Head</p>
                </div>
            </div>
        </div>
    </section>

    <section class="partners-section">
        <div class="container">
            <h2>Our Partners</h2>
            <div class="partners-grid">
                <div class="partner-card">
                    <img src="https://via.placeholder.com/150x80/e0e0e0/333333?text=Partner+1" alt="Partner 1" />
                </div>
                <div class="partner-card">
                    <img src="https://via.placeholder.com/150x80/e0e0e0/333333?text=Partner+2" alt="Partner 2" />
                </div>
                <div class="partner-card">
                    <img src="https://via.placeholder.com/150x80/e0e0e0/333333?text=Partner+3" alt="Partner 3" />
                </div>
                <div class="partner-card">
                    <img src="https://via.placeholder.com/150x80/e0e0e0/333333?text=Partner+4" alt="Partner 4" />
                </div>
                <div class="partner-card">
                    <img src="https://via.placeholder.com/150x80/e0e0e0/333333?text=Partner+5" alt="Partner 5" />
                </div>
            </div>
        </div>
    </section>
</main>
