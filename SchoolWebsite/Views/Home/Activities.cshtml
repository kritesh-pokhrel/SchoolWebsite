@{
    ViewBag.Title = "Activities";
}

<section class="events-page">
    <div class="container">
        <div class="page-header">
            <h1>
                Upcoming <span class="highlight">Events</span>
            </h1>
            <p class="sub-text">
                Stay updated with all school activities and programs
            </p>
        </div>

        <div class="events-grid">
            <div class="event-card">

                <div class="event-date">
                    <span class="day">30</span>
                    <span class="month">May</span>
                </div>

                <div class="event-content">
                    <h3>Annual Sports Day</h3>
                    <p>
                        A full day of sports activities, competitions, and student performances.
                    </p>
                    <a href="#" class="event-link">View Details →</a>
                </div>

            </div>
            <div class="event-card">

                <div class="event-date">
                    <span class="day">12</span>
                    <span class="month">Jun</span>
                </div>

                <div class="event-content">
                    <h3>Science Exhibition</h3>
                    <p>
                        Students showcase innovative science projects and experiments.
                    </p>
                    <a href="#" class="event-link">View Details →</a>
                </div>

            </div>
            <div class="event-card">

                <div class="event-date">
                    <span class="day">01</span>
                    <span class="month">Jul</span>
                </div>

                <div class="event-content">
                    <h3>Parent-Teacher Meeting</h3>
                    <p>
                        Discussion between parents and teachers about student progress.
                    </p>
                    <a href="#" class="event-link">View Details →</a>
                </div>

            </div>
            <div class="event-card">

                <div class="event-date">
                    <span class="day">15</span>
                    <span class="month">Jul</span>
                </div>

                <div class="event-content">
                    <h3>Cultural Program</h3>
                    <p>
                        Students perform dance, drama, and cultural presentations.
                    </p>
                    <a href="#" class="event-link">View Details →</a>
                </div>

            </div>
            <div class="event-card">

                <div class="event-date">
                    <span class="day">28</span>
                    <span class="month">Aug</span>
                </div>

                <div class="event-content">
                    <h3>Educational Tour</h3>
                    <p>
                        A field trip for practical learning and real-world exposure.
                    </p>
                    <a href="#" class="event-link">View Details →</a>
                </div>

            </div>

        </div>

    </div>

</section>