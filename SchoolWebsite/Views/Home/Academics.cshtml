@{
    ViewData["Title"] = "Home";
}


<section class="academics-page">

    <div class="container">

        <div class="academics-layout">

            <!-- LEFT CONTENT -->
            <div class="academics-content">

                <!-- HERO IMAGE -->
                <div class="academic-banner">
                    <img src="https://images.unsplash.com/photo-1509062522246-3755977927d7?q=80&w=1400" />
                </div>

                <!-- IPC SECTION -->
                <div class="ipc-section">

                    <div class="ipc-content">

                        <div class="ipc-text">

                            <div class="small-title">
                                International
                            </div>

                            <h2>
                                Primary Curriculum
                            </h2>

                            <p>
                                The International Primary Curriculum (IPC) is a thematic and
                                creative curriculum designed for children aged 5–11 years.
                                It develops international mindedness and encourages students
                                to become independent learners.
                            </p>

                            <p>
                                IPC combines rigorous learning with engaging activities that
                                make education exciting and meaningful.
                            </p>

                        </div>

                        <div class="ipc-image">
                            <img src="https://images.unsplash.com/photo-1588072432836-e10032774350?q=80&w=1200" />
                        </div>

                    </div>

                </div>

                <!-- MILESTONES -->
                <div class="milestone-tabs">

                    <div class="milestone active">
                        <h4>Milestone 1</h4>
                        <p>Grade 1 - 2</p>
                    </div>

                    <div class="milestone">
                        <h4>Milestone 2</h4>
                        <p>Grade 3 - 4</p>
                    </div>

                    <div class="milestone">
                        <h4>Milestone 3</h4>
                        <p>Grade 5 - 6</p>
                    </div>

                </div>

                <!-- IPC DETAILS -->
                <div class="ipc-details">

                    <div class="details-image">
                        <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1200" />
                    </div>

                    <div class="details-text">

                        <p>
                            IPC has specially designed thematic units through which students
                            learn different subjects in an engaging and meaningful way.
                        </p>

                        <p>
                            The curriculum helps children develop personal goals,
                            international understanding and subject knowledge.
                        </p>

                        <p>
                            Learning is student-centered and activity-based, helping
                            children gain confidence, creativity and communication skills.
                        </p>

                    </div>

                </div>

                <!-- SUBJECTS -->
                <section class="subjects-section">

                    <div class="section-header">
                        <span>Explore</span>
                        <h2>IPC Subjects</h2>
                    </div>

                    <div class="subjects-grid">

                        <div class="subject-card">
                            <div class="subject-icon">
                                <i class="fa-solid fa-book"></i>
                            </div>
                            <h4>Literacy</h4>
                        </div>

                        <div class="subject-card">
                            <div class="subject-icon">
                                <i class="fa-solid fa-calculator"></i>
                            </div>
                            <h4>Numeracy</h4>
                        </div>

                        <div class="subject-card">
                            <div class="subject-icon">
                                <i class="fa-solid fa-music"></i>
                            </div>
                            <h4>Music</h4>
                        </div>

                        <div class="subject-card">
                            <div class="subject-icon">
                                <i class="fa-solid fa-earth-asia"></i>
                            </div>
                            <h4>Geography</h4>
                        </div>

                        <div class="subject-card">
                            <div class="subject-icon">
                                <i class="fa-solid fa-flask"></i>
                            </div>
                            <h4>Science</h4>
                        </div>

                    </div>

                </section>

                <!-- PROCESS -->
                <section class="process-section">

                    <div class="section-header">
                        <span>Learning</span>
                        <h2>Process to Facilitate Learning</h2>
                    </div>

                    <div class="process-grid">

                        <div class="process-card">
                            <h4>Entry Point</h4>

                            <p>
                                Students are introduced to topics through engaging and
                                creative classroom activities.
                            </p>
                        </div>

                        <div class="process-card">
                            <h4>Knowledge Harvest</h4>

                            <p>
                                Teachers identify existing knowledge and build stronger
                                conceptual understanding.
                            </p>
                        </div>

                        <div class="process-card">
                            <h4>Explaining Theme</h4>

                            <p>
                                Themes are explored through collaboration, activities
                                and project based learning.
                            </p>
                        </div>

                    </div>

                </section>

                <!-- NEWSLETTER -->
                <section class="newsletter-section">

                    <div class="section-header">
                        <span>School</span>
                        <h2>Digital Newsletter</h2>
                    </div>

                    <div class="newsletter-grid">

                        <div class="newsletter-card">

                            <img src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=1200" />

                            <div class="newsletter-info">
                                <h4>ISSUE NO 1</h4>
                            </div>

                        </div>

                        <div class="newsletter-card">

                            <img src="https://images.unsplash.com/photo-1513258496099-48168024aec0?q=80&w=1200" />

                            <div class="newsletter-info">
                                <h4>ISSUE NO 2</h4>
                            </div>

                        </div>

                    </div>

                </section>

            </div>

            <!-- SIDEBAR -->
            <aside class="academics-sidebar">

                <div class="sidebar-box">

                    <h3>Academics.</h3>

                    <ul>

                        <li>
                            <a href="#">Overview</a>
                        </li>

                        <li>
                            <a href="#">Primary School</a>
                        </li>

                        <li>
                            <a href="#">Middle School</a>
                        </li>

                        <li>
                            <a href="#">High School</a>
                        </li>

                        <li>
                            <a href="#">Assessment</a>
                        </li>

                        <li>
                            <a href="#">Learning Support</a>
                        </li>

                    </ul>

                </div>

            </aside>

        </div>

    </div>

</section>