@{
    ViewBag.Title = "About Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<main class="about-page">
    <section class="hero-section">
        <div class="container">
            <div class="hero-content">
                <h1>@Model.HeroTitle</h1>
                <nav class="breadcrumb">
                    <a href="@Url.Action("Index", "Home")">Home</a>
                    <span>/</span>
                    <span>About Us</span>
                </nav>
            </div>
        </div>
    </section>

    <section class="welcome-section">
        <div class="container">
            <div class="content-wrapper">
                <div class="main-content">
                    <h2>@Model.WelcomeTitle</h2>
                    <div class="welcome-text">
                        @Html.Raw(Model.WelcomeContent)
                    </div>
                    <div class="welcome-images">
                        <img src="/Content/images/lab.jpg" alt="Students in lab" />
                        <img src="/Content/images/sports.jpg" alt="Students in sports" />
                    </div>
                </div>
                <aside class="sidebar">
                    <div class="related-links">
                        <h3>Related Links</h3>
                        <ul>
                            @foreach (var link in Model.RelatedLinks)
                            {
                                <li><a href="@link.Url">@link.Title</a></li>
                            }
                        </ul>
                    </div>
                </aside>
            </div>
        </div>
    </section>

    <section class="who-we-are-section">
        <div class="container">
            <h2>@Model.WhoWeAreTitle</h2>
            <div class="who-we-are-content">
                @Html.Raw(Model.WhoWeAreContent)
            </div>
        </div>
    </section>

    <section class="employee-section">
        <div class="container">
            <h2>Employee of the Term</h2>
            <div class="employee-grid">
                @foreach (var employee in Model.EmployeesOfTerm)
                {
                    <div class="employee-card">
                        <img src="/Content/images/@employee.Image" alt="@employee.Name" />
                        <h4>@employee.Name</h4>
                        <p>@employee.Position</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="employee-section">
        <div class="container">
            <h2>Employee of the Year</h2>
            <div class="employee-grid">
                @foreach (var employee in Model.EmployeesOfYear)
                {
                    <div class="employee-card">
                        <img src="/Content/images/@employee.Image" alt="@employee.Name" />
                        <h4>@employee.Name</h4>
                        <p>@employee.Position</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="partners-section">
        <div class="container">
            <h2>Learning Partners</h2>
            <div class="partners-grid">
                @foreach (var partner in Model.LearningPartners)
                {
                    <div class="partner-card">
                        <img src="/Content/images/@partner.Logo" alt="@partner.Name" />
                    </div>
                }
            </div>
        </div>
    </section>
</main>
